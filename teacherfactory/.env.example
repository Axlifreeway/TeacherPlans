# Пример файла переменных окружения для TeacherFactory
# Скопируйте этот файл в .env и заполните своими значениями
# Файл .env НЕ должен попадать в репозиторий (добавлен в .gitignore)

# Groq API ключ (получить бесплатно: https://console.groq.com/keys)
GROQ_API_KEY=gsk_...

# Дополнительные настройки (опционально)
# GROQ_MODEL=llama-3.1-8b-instant
